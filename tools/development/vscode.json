{
  "go.toolsManagement.autoUpdate": true,
  "go.lintTool": "golangci-lint",
  "go.lintFlags": ["--config", "${workspaceFolder}/tools/development/.golangci.yml"],
  "go.formatTool": "goimports",
  "go.testTimeout": "120s",
  "go.testFlags": ["-race"],
  "[go]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "files.exclude": {
    "**/bin": true
  },
  "search.exclude": {
    "internal/platform/database/sqlc/*.go": true
  }
}

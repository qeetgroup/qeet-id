# Claude Code — keep shared config (settings.json, commands/, agents/, README.md),
# ignore personal overrides and runtime artifacts.
.claude/settings.local.json
.claude/.cache/
.claude/.session/
.claude/logs/

# graphify output (regenerated on demand)
graphify-out/

# Go — build output, test/coverage artifacts (merged from backend/.gitignore on hoist)
/bin/
*.test
*.out
coverage.html

# Env / secrets — never commit (but keep .env*.example templates)
.env
.env.local
.env.*.local
.env.prod
.env.staging
.env.production
*.pem
*.key
*.crt
*.p12
*.pfx
# Anchored to repo root so it ignores a top-level secrets/ material dir WITHOUT
# hiding the Go source package internal/developer/credentials/secrets/.
/secrets/

# Logs
*.log
logs/

# Tooling caches
.cache/

# OS / archive
*.tar
*.tar.gz
*.zip

# product-manager agent run logs (see .claude/README.md)
.claude/logs/

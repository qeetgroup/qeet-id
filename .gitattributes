# Normalize line endings to LF in the repo, regardless of OS.
* text=auto eol=lf

# ── Source code (always LF) ────────────────────────────────────────────────
*.go        text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.sql       text eol=lf
*.sh        text eol=lf

# Docs / config
*.md        text eol=lf
*.txt       text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf
*.env*      text eol=lf

# ── Lockfiles ─ vendored output, exclude from rebases / diff-noise ─────────
go.sum               text eol=lf -diff

# ── Binary assets ──────────────────────────────────────────────────────────
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.webp   binary
*.avif   binary
*.svg    text eol=lf
*.pdf    binary
*.zip    binary
*.gz     binary
*.tar    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.eot    binary

# ── Generated / vendored — collapse in diffs ───────────────────────────────
**/*.gen.go               linguist-generated

# ── Vendored docs that aren't ours ─────────────────────────────────────────
documents/source-requirements/** linguist-vendored

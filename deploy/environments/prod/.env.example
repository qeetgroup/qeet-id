# ─────────────────────────────────────────────────────────────────────────────
# Qeet ID — Production Environment Variables
# Copy this file to .env and fill in every blank value.
# Generate secrets with the commands in ../../../runbooks/secrets.md
# ─────────────────────────────────────────────────────────────────────────────

# ── Images ────────────────────────────────────────────────────────────────────
# Pin to an exact release tag — never use "latest" in production.
APP_IMAGE=ghcr.io/qeetgroup/qeet-id:X.Y.Z
MIGRATE_IMAGE=ghcr.io/qeetgroup/qeet-id-migrate:X.Y.Z

# ── Service ───────────────────────────────────────────────────────────────────
SERVICE_ENV=prod
HTTP_PORT=4001
LOG_LEVEL=info

# ── Database (AWS RDS) ────────────────────────────────────────────────────────
# Format: postgres://USER:PASSWORD@RDS-ENDPOINT:5432/DB?sslmode=require
DB_URL=postgres://qeetid:CHANGE_ME@your-db.xxxx.us-east-1.rds.amazonaws.com:5432/qeet_id?sslmode=require
DB_MIN_CONNS=2
DB_MAX_CONNS=20

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=

# Generate: see runbooks/secrets.md  (EC P-256 PEM, single line with \n)
JWT_SIGNING_KEY=

JWT_ISSUER=https://id.qeet.in
JWT_AUDIENCE=qeet-id
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# ── Secrets vault ─────────────────────────────────────────────────────────────
# SECRETS_PROVIDER: "static" (key below) or "aws-kms" (requires KMS_KEY_ID)
SECRETS_PROVIDER=static
# Generate: openssl rand -base64 32
SECRETS_KEY=

# ── Public URLs ───────────────────────────────────────────────────────────────
APP_BASE_URL=https://console.id.qeet.in
LOGIN_BASE_URL=https://auth.id.qeet.in
ALLOWED_ORIGINS=https://console.id.qeet.in,https://auth.id.qeet.in

# ── Redis (local container) ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── WebAuthn / Passkeys ───────────────────────────────────────────────────────
WEBAUTHN_RP_ID=id.qeet.in
WEBAUTHN_RP_DISPLAY_NAME=Qeet ID
WEBAUTHN_RP_ORIGINS=https://auth.id.qeet.in,https://console.id.qeet.in

# ── CSRF ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
CSRF_KEY=
CSRF_COOKIE_DOMAIN=.id.qeet.in

# ── SAML IdP ──────────────────────────────────────────────────────────────────
# Generate: see runbooks/secrets.md  (RSA PEM, single line with \n)
SAML_IDP_KEY=
SAML_IDP_CERT=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave blank in dev — emails print to backend logs.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@id.qeet.in

# ── SMS (Twilio) — optional ───────────────────────────────────────────────────
# Leave blank to skip SMS OTP (fallback: email OTP).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── Breach-password detection (HIBP) ─────────────────────────────────────────
BREACHED_PASSWORD_CHECK=true
BREACHED_PASSWORD_MIN_COUNT=1

# ── Payments — disabled until keys are set ───────────────────────────────────
# Stripe (international card payments)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Razorpay (India INR payments)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# ── Observability — optional ──────────────────────────────────────────────────
# Leave blank to disable distributed tracing (metrics always on at /metrics).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

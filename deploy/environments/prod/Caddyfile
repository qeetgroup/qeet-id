# Caddy: automatic HTTPS (Let's Encrypt) + reverse proxy to the Go API.
# Caddy obtains and renews TLS certificates automatically.
# Port 80/443 must be open in your EC2 security group.

(common) {
	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options   "nosniff"
		X-Frame-Options          "SAMEORIGIN"
		Referrer-Policy          "strict-origin-when-cross-origin"
		-Server
	}

	# Never expose Prometheus metrics publicly — scrape internally if needed.
	@metrics path /metrics
	respond @metrics 404

	reverse_proxy app:4001 {
		health_uri      /healthz
		health_interval 15s
		health_timeout  3s
	}
}

# API + auth flows
id.qeet.in         { import common }

# Hosted login (OAuth consent, device flow, password reset)
auth.id.qeet.in    { import common }

# Admin console backend proxy (SPA is hosted separately — see deploy.md)
console.id.qeet.in { import common }
